{
  "name": "busgo-backend",
  "type": "module",
  "packageManager": "yarn@4.11.0",
  "scripts": {
    "dev": "nodemon --watch src --ext ts --exec tsx src/app/api.ts",
    "clean": "rm -rf dist",
    "build": "yarn clean && tsc",
    "prestart": "yarn build",
    "start": "node dist/app/api.js",
    "format": "prettier --write \"src/**/*.{ts,js,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,js,json}\"",
    "migration:create": "kysely migrate:make",
    "migration:down": "kysely migrate:down",
    "migrate": "kysely migrate:latest"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/static": "^9.1.3",
    "@fastify/swagger": "^9.6.1",
    "dotenv": "^17.2.3",
    "fast-jwt": "^6.1.0",
    "fastify": "^5.6.2",
    "fastify-plugin": "^5.0.1",
    "fastify-type-provider-zod": "^6.1.0",
    "kysely": "^0.28.16",
    "kysely-ctl": "^0.20.0",
    "pg": "^8.16.3",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@types/node": "^25.0.3",
    "@types/pg": "^8",
    "nodemon": "^3.1.11",
    "prettier": "^3.7.4",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3"
  }
}
